# Copiar como .env y ajustar los valores
# cp .env.example .env

# Base de datos
DB_HOST=localhost
DB_NAME=inscripciones_club
DB_USER=root
DB_PASS=

# URL base del sitio (requerida para protección CSRF/Origin)
APP_URL=https://tu-dominio.com

# Correo (PHPMailer)
EMAIL_HOST=smtp.ejemplo.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=

# Opcional
SHOW_CUPOS=false

# API externa (responsables, participantes, inscripción)
# API_RESPONSABLES=https://api.ejemplo.com/responsables
# API_PARTICIPANTES=https://api.ejemplo.com/participantes
# API_INSCRIPCION=https://api.ejemplo.com (se completa con /{Codigo_Facturacion}/participantes)
# BEARER=tu_token_bearer
